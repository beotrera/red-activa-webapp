# URL base del backend — solo host + puerto, SIN trailing slash ni "/api".
# Las rutas individuales (/api/persons, /auth/login, etc.) se concatenan en el código.
# Ejemplos:
#   Desarrollo local → http://localhost:3001
#   Producción       → https://api.redactiva.gob.ar
VITE_API_BASE_URL="http://localhost:3001"
